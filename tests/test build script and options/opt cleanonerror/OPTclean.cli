# run sjasmplus with full output to exercise the "Deleting files on error" messages
# filter and count matching lines using grep
cleaned_lines_cnt=$($MEMCHECK "$EXE" --nologo --msg=all --fullpath "${options[@]}" "$file_asm" 2>&1 | \
    grep -c -E "(^Deleting files on error|OPTclean\.bin$)")
# bin file should not exist && at least 2 filtered lines expected
[[ ! -f OPTclean.bin && $cleaned_lines_cnt -ge 2 ]]
last_result=$?
